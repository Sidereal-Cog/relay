<Window
  x:Class="NotificationSoundRouter.UI.SettingsWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Title="Notification Sound Router — Settings"
  Width="720" Height="620"
  MinWidth="560" MinHeight="420"
  WindowStartupLocation="CenterScreen"
  ResizeMode="CanResize"
  Background="#ffffff"
  FontFamily="Inter, Space Grotesk, Segoe UI, sans-serif">

  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="BrandStyles.xaml" />
      </ResourceDictionary.MergedDictionaries>

      <!-- DataTemplate for a single SoundRule row -->
      <DataTemplate x:Key="RuleRowTemplate">
        <Border Margin="0,4,0,0" Padding="8" BorderBrush="{StaticResource SilverBrush}" BorderThickness="1" CornerRadius="6">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="90" />
              <ColumnDefinition Width="110" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ComboBox Grid.Column="0" Margin="0,0,8,0"
                      Style="{StaticResource BrandComboBoxStyle}"
                      SelectedValue="{Binding MatchField, Mode=TwoWay}"
                      SelectedValuePath="Tag">
              <ComboBoxItem Content="Title" Tag="Title" />
              <ComboBoxItem Content="Body"  Tag="Body"  />
            </ComboBox>

            <ComboBox Grid.Column="1" Margin="0,0,8,0"
                      Style="{StaticResource BrandComboBoxStyle}"
                      SelectedValue="{Binding MatchType, Mode=TwoWay}"
                      SelectedValuePath="Tag">
              <ComboBoxItem Content="Contains"   Tag="Contains"   />
              <ComboBoxItem Content="Starts with" Tag="StartsWith" />
              <ComboBoxItem Content="Ends with"   Tag="EndsWith"   />
              <ComboBoxItem Content="Equals"      Tag="Equals"     />
            </ComboBox>

            <TextBox Grid.Column="2" Margin="0,0,8,0"
                     Style="{StaticResource InputStyle}"
                     Text="{Binding MatchValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="Match value" />

            <Grid Grid.Column="3" Margin="0,0,8,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <TextBox Grid.Column="0"
                       Style="{StaticResource InputStyle}"
                       Text="{Binding Sound, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       ToolTip="Sound file (.wav)" />
              <Button Grid.Column="1" Margin="4,0,0,0"
                      Style="{StaticResource SecondaryButtonStyle}"
                      Padding="8,6"
                      Tag="{Binding}"
                      Click="OnBrowseRuleSoundClicked"
                      Content="Browse" />
            </Grid>

            <Button Grid.Column="4"
                    Style="{StaticResource DestructiveButtonStyle}"
                    Tag="{Binding}"
                    Click="OnRemoveRuleClicked"
                    Content="Remove" />
          </Grid>
        </Border>
      </DataTemplate>

      <!-- DataTemplate for a single AppConfig row (Expander) -->
      <DataTemplate x:Key="AppRowTemplate">
        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,8">
          <StackPanel>
            <!-- App header row -->
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>

              <TextBlock Grid.Column="0"
                         Style="{StaticResource LabelStyle}"
                         FontWeight="SemiBold"
                         Text="{Binding DisplayName}"
                         VerticalAlignment="Center"
                         TextTrimming="CharacterEllipsis" />

              <TextBox Grid.Column="1" Margin="8,0"
                       Style="{StaticResource InputStyle}"
                       Text="{Binding Sound, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       ToolTip="Sound file (.wav)" />

              <Button Grid.Column="2" Margin="0,0,8,0"
                      Style="{StaticResource SecondaryButtonStyle}"
                      Padding="12,6"
                      Tag="{Binding}"
                      Click="OnBrowseAppSoundClicked"
                      Content="Browse" />

              <Button Grid.Column="3"
                      Style="{StaticResource DestructiveButtonStyle}"
                      Tag="{Binding}"
                      Click="OnRemoveAppClicked"
                      Content="Remove" />
            </Grid>

            <!-- Rules sub-section (collapsible) -->
            <Expander Margin="0,12,0,0" IsExpanded="False">
              <Expander.Header>
                <TextBlock Style="{StaticResource SecondaryLabelStyle}" Text="Content rules" />
              </Expander.Header>
              <StackPanel Margin="0,8,0,0">
                <ItemsControl ItemsSource="{Binding Rules}"
                              ItemTemplate="{StaticResource RuleRowTemplate}" />
                <Button Margin="0,8,0,0" HorizontalAlignment="Left"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Padding="12,6"
                        Tag="{Binding}"
                        Click="OnAddRuleClicked"
                        Content="Add rule" />
              </StackPanel>
            </Expander>
          </StackPanel>
        </Border>
      </DataTemplate>
    </ResourceDictionary>
  </Window.Resources>

  <DockPanel Margin="24">

    <!-- ── Global settings ─────────────────────── -->
    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,24">
      <TextBlock Style="{StaticResource HeadingStyle}" Text="Notification Sound Router" Margin="0,0,0,16" />

      <!-- Default sound -->
      <TextBlock Style="{StaticResource LabelStyle}" Text="Default sound" Margin="0,0,0,4" />
      <Grid Margin="0,0,0,16">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBox x:Name="DefaultSoundTextBox"
                 Grid.Column="0"
                 Style="{StaticResource InputStyle}" />
        <Button Grid.Column="1" Margin="8,0,0,0"
                Style="{StaticResource SecondaryButtonStyle}"
                Padding="12,6"
                Click="OnBrowseDefaultSoundClicked"
                Content="Browse" />
      </Grid>

      <!-- Toggles -->
      <CheckBox x:Name="EnabledCheckBox"
                Style="{StaticResource BrandCheckBoxStyle}"
                Content="Sound routing enabled"
                Margin="0,0,0,8" />
      <CheckBox x:Name="RestoreOnExitCheckBox"
                Style="{StaticResource BrandCheckBoxStyle}"
                Content="Restore Windows notification sound on exit" />

      <Separator Style="{StaticResource DividerStyle}" Margin="0,16,0,0" />
    </StackPanel>

    <!-- ── Save / Cancel ───────────────────────── -->
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                HorizontalAlignment="Right" Margin="0,16,0,0">
      <Button Style="{StaticResource SecondaryButtonStyle}"
              Padding="20,8" Margin="0,0,8,0"
              Click="OnCancelClicked"
              Content="Cancel" />
      <Button Style="{StaticResource PrimaryButtonStyle}"
              Padding="20,8"
              Click="OnSaveClicked"
              Content="Save" />
    </StackPanel>

    <!-- ── App list ─────────────────────────────── -->
    <DockPanel>
      <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
        <TextBlock Style="{StaticResource HeadingStyle}"
                   Text="App rules"
                   VerticalAlignment="Center" />
        <Button DockPanel.Dock="Right" HorizontalAlignment="Right"
                Style="{StaticResource PrimaryButtonStyle}"
                Padding="16,8"
                Click="OnAddAppClicked"
                Content="Add app" />
      </DockPanel>

      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <ItemsControl x:Name="AppsItemsControl"
                      ItemTemplate="{StaticResource AppRowTemplate}" />
      </ScrollViewer>
    </DockPanel>

  </DockPanel>
</Window>
