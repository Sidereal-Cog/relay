<Window
  x:Class="NotificationSoundRouter.UI.AppPickerDialog"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Title="Add app"
  Width="400" Height="440"
  ResizeMode="NoResize"
  WindowStartupLocation="CenterOwner"
  Background="#ffffff"
  FontFamily="Inter, Space Grotesk, Segoe UI, sans-serif">

  <Window.Resources>
    <ResourceDictionary Source="BrandStyles.xaml" />
  </Window.Resources>

  <Border Margin="24" CornerRadius="12">
    <DockPanel>

      <TextBlock DockPanel.Dock="Top"
                 Style="{StaticResource HeadingStyle}"
                 Text="Add app"
                 Margin="0,0,0,8" />

      <TextBlock DockPanel.Dock="Top"
                 Style="{StaticResource SecondaryLabelStyle}"
                 TextWrapping="Wrap"
                 Text="Apps listed here have recently sent a notification. Select one to add a sound rule."
                 Margin="0,0,0,16" />

      <!-- Buttons -->
      <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                  HorizontalAlignment="Right" Margin="0,16,0,0">
        <Button Style="{StaticResource SecondaryButtonStyle}"
                Padding="20,8" Margin="0,0,8,0"
                Click="OnCancelClicked"
                Content="Cancel" />
        <Button Style="{StaticResource PrimaryButtonStyle}"
                Padding="20,8"
                Click="OnOkClicked"
                Content="Add" />
      </StackPanel>

      <!-- App list -->
      <Border Style="{StaticResource CardStyle}" Padding="0">
        <ListBox x:Name="AppListBox"
                 BorderThickness="0"
                 Background="Transparent"
                 SelectionMode="Single"
                 MouseDoubleClick="OnListBoxDoubleClick">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <StackPanel Margin="12,8">
                <TextBlock Style="{StaticResource LabelStyle}"
                           Text="{Binding DisplayName}"
                           FontWeight="SemiBold" />
                <TextBlock Style="{StaticResource SecondaryLabelStyle}"
                           Text="{Binding AppId}"
                           TextTrimming="CharacterEllipsis" />
              </StackPanel>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Border>

    </DockPanel>
  </Border>
</Window>
